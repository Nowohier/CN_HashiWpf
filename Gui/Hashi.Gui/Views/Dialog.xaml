<mah:MetroWindow x:Class="Hashi.Gui.Views.Dialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:dialog="clr-namespace:Hashi.Gui.ViewModels"
                 xmlns:ns="clr-namespace:Hashi.Gui.Localization"
                 mc:Ignorable="d"
                 Title="{Binding Caption, UpdateSourceTrigger=PropertyChanged}"
                 d:DataContext="{d:DesignInstance {x:Type dialog:DialogViewModel}, IsDesignTimeCreatable=False}"
                 Width="400" SizeToContent="Height" ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
                 WindowTitleBrush="{StaticResource BasicBrush}">
    <mah:MetroWindow.Resources>
        <Style x:Key="ImageStyle" TargetType="iconPacks:PackIconBase">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
    </mah:MetroWindow.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BasicBrush}"
                BorderThickness="0,1,0,1">
            <Grid Margin="0,10,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="{x:Type ColumnDefinition}">
                                <Setter Property="Width" Value="50" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNone}" Value="True">
                                        <Setter Property="Width" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <iconPacks:PackIconMaterial Grid.Column="0" Kind="Check" Foreground="Green"
                                            Style="{StaticResource ImageStyle}"
                                            Visibility="{Binding IsSuccess, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <iconPacks:PackIconMaterial Grid.Column="0" Kind="Information" Foreground="Blue"
                                            Style="{StaticResource ImageStyle}"
                                            Visibility="{Binding IsAsterisk, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <iconPacks:PackIconMaterial Grid.Column="0" Kind="AlertCircle" Foreground="Red"
                                            Style="{StaticResource ImageStyle}"
                                            Visibility="{Binding IsError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <iconPacks:PackIconMaterial Grid.Column="0" Kind="Exclamation" Foreground="Blue"
                                            Style="{StaticResource ImageStyle}"
                                            Visibility="{Binding IsExclamation, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <iconPacks:PackIconMaterial Grid.Column="0" Kind="HandBackRight" Foreground="Red"
                                            Style="{StaticResource ImageStyle}"
                                            Visibility="{Binding IsHand, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <iconPacks:PackIconMaterial Grid.Column="0" Kind="Information" Foreground="Blue"
                                            Style="{StaticResource ImageStyle}"
                                            Visibility="{Binding IsInformation, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <iconPacks:PackIconMaterial Grid.Column="0" Kind="HelpCircle" Foreground="BlueViolet"
                                            Style="{StaticResource ImageStyle}"
                                            Visibility="{Binding IsQuestion, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <iconPacks:PackIconMaterial Grid.Column="0" Kind="Stop" Foreground="Red"
                                            Style="{StaticResource ImageStyle}"
                                            Visibility="{Binding IsStop, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <iconPacks:PackIconMaterial Grid.Column="0" Kind="Alert" Foreground="Orange"
                                            Style="{StaticResource ImageStyle}"
                                            Visibility="{Binding IsWarning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Grid.Column="1" Margin="5,0,0,0"
                           Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                           TextWrapping="WrapWithOverflow" VerticalAlignment="Center" />
            </Grid>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Margin="5,0,0,0" Height="26" HorizontalAlignment="Right" Command="{Binding YesCommand}"
                    Visibility="{Binding ShowYesNo, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Check" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Height="14" Width="14" Foreground="Green" />
                    <Label Padding="5,0,5,0" Content="{ns:Loc DialogYes}" FontWeight="Normal" />
                </StackPanel>
            </Button>
            <Button Margin="5,0,0,0" Height="26" HorizontalAlignment="Right" Command="{Binding NoCommand}"
                    Visibility="{Binding ShowYesNo, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Close" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Height="12" Width="12" Foreground="Red" />
                    <Label Padding="5,0,5,0" Content="{ns:Loc DialogNo}" FontWeight="Normal" />
                </StackPanel>
            </Button>
            <Button Margin="5,0,0,0" Height="26" HorizontalAlignment="Right" Command="{Binding OkCommand}"
                    Visibility="{Binding ShowOk, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Check" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Height="14" Width="14" Foreground="Green" />
                    <Label Padding="5,0,5,0" Content="{ns:Loc DialogConfirm}" FontWeight="Normal" />
                </StackPanel>
            </Button>
            <Button Margin="5,0,0,0" Height="26" Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window, Mode=FindAncestor}}"
                    Visibility="{Binding ShowCancel, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Close" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Height="12" Width="12" Foreground="Red" />
                    <Label Padding="5,0,5,0" Content="{ns:Loc DialogAbort}" FontWeight="Normal" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</mah:MetroWindow>