<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                    xmlns:viewModels="clr-namespace:Hashi.Gui.ViewModels"
                    xmlns:behaviors="clr-namespace:Hashi.Gui.Behaviors"
                    xmlns:enums="clr-namespace:Hashi.Enums;assembly=Hashi.Enums">

    <DataTemplate x:Key="DataTemplateIsland" DataType="{x:Type viewModels:IslandViewModel}">
        <Border BorderThickness="0">
            <Grid UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Rectangle Width="30" Height="15" Style="{StaticResource PotentialConnectionStyle}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Visibility="{Binding IsHighlightHorizontalRight, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Rectangle Width="30" Height="15" Style="{StaticResource PotentialConnectionStyle}"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Visibility="{Binding IsHighlightHorizontalLeft, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Rectangle Width="15" Height="30" Style="{StaticResource PotentialConnectionStyle}"
                           HorizontalAlignment="Center" VerticalAlignment="Top"
                           Visibility="{Binding IsHighlightVerticalTop, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Rectangle Width="15" Height="30" Style="{StaticResource PotentialConnectionStyle}"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Visibility="{Binding IsHighlightVerticalBottom, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Line X1="0" Y1="0" X2="60" Y2="0" Style="{StaticResource GridLinesStyle}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Visibility="{Binding RelativeSource={RelativeSource AncestorType=mah:MetroWindow, Mode=FindAncestor}, Path=DataContext.(viewModels:MainViewModel.Settings).AreGridLinesEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Line X1="0" Y1="0" X2="0" Y2="60" Style="{StaticResource GridLinesStyle}" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Visibility="{Binding RelativeSource={RelativeSource AncestorType=mah:MetroWindow, Mode=FindAncestor}, Path=DataContext.(viewModels:MainViewModel.Settings).AreGridLinesEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!--Double Lines horizontal-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="-2" X2="60" Y2="-2" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.HorizontalDouble}" />
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="8" X2="60" Y2="8" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.HorizontalDouble}" />

                <!--Double Lines horizontal right-->
                <Line Style="{StaticResource BridgeStyle}" X1="30" Y1="-2" X2="60" Y2="-2" HorizontalAlignment="Right"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.HorizontalDoubleRight}" />
                <Line Style="{StaticResource BridgeStyle}" X1="30" Y1="8" X2="60" Y2="8" HorizontalAlignment="Right"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.HorizontalDoubleRight}" />

                <!--Double Lines horizontal left-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="-2" X2="30" Y2="-2" HorizontalAlignment="Left"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.HorizontalDoubleLeft}" />
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="8" X2="30" Y2="8" HorizontalAlignment="Left"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.HorizontalDoubleLeft}" />

                <!--Double Lines vertical-->
                <Line Style="{StaticResource BridgeStyle}" X1="-3" Y1="0" X2="-3" Y2="60" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.VerticalDouble}" />
                <Line Style="{StaticResource BridgeStyle}" X1="8" Y1="0" X2="8" Y2="60" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.VerticalDouble}" />

                <!--Double Lines vertical top-->
                <Line Style="{StaticResource BridgeStyle}" X1="-3" Y1="0" X2="-3" Y2="30" HorizontalAlignment="Center"
                      VerticalAlignment="Top" Tag="{x:Static enums:BridgeTypeEnum.VerticalDoubleUp}" />
                <Line Style="{StaticResource BridgeStyle}" X1="8" Y1="0" X2="8" Y2="30" HorizontalAlignment="Center"
                      VerticalAlignment="Top" Tag="{x:Static enums:BridgeTypeEnum.VerticalDoubleUp}" />

                <!--Double Lines vertical bottom-->
                <Line Style="{StaticResource BridgeStyle}" X1="-3" Y1="30" X2="-3" Y2="60" HorizontalAlignment="Center"
                      VerticalAlignment="Bottom" Tag="{x:Static enums:BridgeTypeEnum.VerticalDoubleDown}" />
                <Line Style="{StaticResource BridgeStyle}" X1="8" Y1="30" X2="8" Y2="60" HorizontalAlignment="Center"
                      VerticalAlignment="Bottom" Tag="{x:Static enums:BridgeTypeEnum.VerticalDoubleDown}" />

                <!--Single line horizontal-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="0" X2="60" Y2="0" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.Horizontal}" />

                <!--Single line horizontal right-->
                <Line Style="{StaticResource BridgeStyle}" X1="30" Y1="0" X2="60" Y2="0" HorizontalAlignment="Right"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.HorizontalRight}" />

                <!--Single line horizontal left-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="0" X2="30" Y2="0" HorizontalAlignment="Left"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.HorizontalLeft}" />

                <!--Single line vertical-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="0" X2="0" Y2="60" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.Vertical}" />

                <!--Single line vertical top-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="0" X2="0" Y2="30" HorizontalAlignment="Center"
                      VerticalAlignment="Top" Tag="{x:Static enums:BridgeTypeEnum.VerticalUp}" />

                <!--Single line vertical bottom-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="30" X2="0" Y2="60" HorizontalAlignment="Center"
                      VerticalAlignment="Bottom" Tag="{x:Static enums:BridgeTypeEnum.VerticalDown}" />

                <Ellipse Width="40" Height="40" Fill="{Binding IslandColor.Brush}" HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Visibility="{Binding MaxConnections, Converter={StaticResource IslandVisibilityConverter}}"
                         IsHitTestVisible="True" AllowDrop="True" />
                <TextBlock Text="{Binding MaxConnections}" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" Foreground="{StaticResource BasicBrush}" FontWeight="Bold"
                           Visibility="{Binding MaxConnections, Converter={StaticResource IslandVisibilityConverter}}"
                           IsHitTestVisible="True" AllowDrop="True" />
                <b:Interaction.Behaviors>
                    <!-- ReSharper disable once MarkupAttributeTypo -->
                    <behaviors:IslandDragDropBehavior
                        DragEnterCommand="{Binding DragEnterCommand}"
                        DragOverCommand="{Binding DragOverCommand}"
                        DragLeaveCommand="{Binding DragLeaveCommand}"
                        DropCommand="{Binding DropCommand}"
                        MouseMoveCommand="{Binding MouseMoveCommand}"
                        MouseLeftButtonDownCommand="{Binding MouseLeftButtonDownCommand}"
                        MouseLeftButtonUpCommand="{Binding MouseLeftButtonUpCommand}"
                        ConnectedViewBox="{Binding RelativeSource={RelativeSource AncestorType=Viewbox, Mode=FindAncestor}}" />
                </b:Interaction.Behaviors>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="DataTemplateLevel1">
        <ItemsControl ItemsSource="{Binding}" ItemTemplate="{DynamicResource DataTemplateIsland}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </DataTemplate>
</ResourceDictionary>