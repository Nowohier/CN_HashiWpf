<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                    xmlns:viewModels="clr-namespace:Hashi.Gui.ViewModels"
                    xmlns:behaviors="clr-namespace:Hashi.Gui.Behaviors"
                    xmlns:collections="clr-namespace:System.Collections;assembly=System.Runtime"
                    xmlns:ns="clr-namespace:Hashi.Gui.Localization">

    <Style x:Key="WindowIconStyle" TargetType="{x:Type iconPacks:PackIconBase}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="MenuButtonStyle" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Height" Value="30" />
        <Setter Property="IsEnabled" Value="True" />
        <Style.Triggers>
            <DataTrigger
                Binding="{Binding Path=DataContext.(viewModels:MainViewModel.IsGeneratingHashiPuzzle), RelativeSource={RelativeSource AncestorType=mah:MetroWindow, Mode=FindAncestor}}"
                Value="True">
                <Setter Property="IsEnabled" Value="False" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MenuGridToggleButtonStyle" TargetType="ToggleButton"
           BasedOn="{StaticResource MahApps.Styles.ToggleButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Height" Value="30" />
        <Setter Property="IsEnabled" Value="True" />
        <Setter Property="ToolTip" Value="{ns:Loc ToggleGridlinesTooltip}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}" BorderThickness="1" CornerRadius="2"
                            Padding="3,0,3,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger
                Binding="{Binding Path=DataContext.(viewModels:MainViewModel.IsGeneratingHashiPuzzle), RelativeSource={RelativeSource AncestorType=mah:MetroWindow, Mode=FindAncestor}}"
                Value="True">
                <Setter Property="IsEnabled" Value="False" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Content">
                    <Setter.Value>
                        <iconPacks:PackIconVaadinIcons Kind="Grid" Width="14" Height="14" VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" />
                    </Setter.Value>
                </Setter>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Mode=Self}}" Value="False">
                <Setter Property="Foreground" Value="{StaticResource MahApps.Brushes.ThemeForeground}" />
                <Setter Property="Content">
                    <Setter.Value>
                        <Grid>
                            <iconPacks:PackIconVaadinIcons Kind="Grid" Width="14" Height="14"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <iconPacks:PackIconPhosphorIcons Kind="ProhibitInsetThin" Width="22" Height="22"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Foreground="Red" />
                        </Grid>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="White" />
                <Setter Property="Foreground" Value="Black" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="GridLinesStyle" TargetType="Line">
        <Setter Property="Stroke" Value="{StaticResource GridLineBrush}" />
        <Setter Property="StrokeDashArray" Value="4,4" />
        <Setter Property="StrokeThickness" Value="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl, Mode=FindAncestor, AncestorLevel=2}, Converter={StaticResource StrokeThicknessConverter}}"/>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="RenderOptions.EdgeMode" Value="Aliased" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="BridgeStyle" TargetType="Line">
        <!-- Set the DataContext to the Line itself. This is a bug fix for unwanted wpf behavior, see:-->
        <!-- https://stackoverflow.com/questions/14282894/wpf-listbox-virtualization-creates-disconnecteditems-->
        <!-- Not implementing this results in potential DataContext={DisconnectedItem} bugs-->
        <Setter Property="DataContext" Value="{Binding}" />
        <Setter Property="Stroke" Value="{StaticResource BasicBrush}" />
        <Setter Property="StrokeThickness" Value="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl, Mode=FindAncestor, AncestorLevel=2}, Converter={StaticResource StrokeThicknessConverter}}"/>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="RenderOptions.EdgeMode" Value="Aliased" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="behaviors:BehaviorInStyleAttacher.Behaviors">
            <Setter.Value>
                <collections:ArrayList>
                    <behaviors:BridgeVisibilityBehavior
                        AllConnections="{Binding AllConnections}"
                        BridgeType="{Binding RelativeSource={RelativeSource AncestorType=Line, Mode=FindAncestor}, Path=Tag, Converter={StaticResource TagToBridgeTypeEnumConverter}}" />
                </collections:ArrayList>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PotentialConnectionStyle" TargetType="Rectangle">
        <Setter Property="Fill" Value="{StaticResource PotentialConnectionBrush}" />
    </Style>
</ResourceDictionary>