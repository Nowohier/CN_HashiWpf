<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                    xmlns:converters="clr-namespace:Hashi.Gui.Converters"
                    xmlns:viewModels="clr-namespace:Hashi.Gui.ViewModels"
                    xmlns:behaviors="clr-namespace:Hashi.Gui.Behaviors"
                    xmlns:enums="clr-namespace:Hashi.Gui.Enums;assembly=Hashi.Enums"
                    xmlns:collections="clr-namespace:System.Collections;assembly=System.Runtime">

    <converters:IslandVisibilityConverter x:Key="IslandVisibilityConverter" />
    <converters:TagToBridgeTypeEnumConverter x:Key="TagToBridgeTypeEnumConverter"/>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <Style x:Key="WindowIconStyle" TargetType="{x:Type iconPacks:PackIconBase}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="GridLinesStyle" TargetType="Line">
        <Setter Property="Stroke" Value="{StaticResource BasicBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="RenderOptions.EdgeMode" Value="Aliased" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="BridgeStyle" TargetType="Line">
        <Setter Property="Stroke" Value="{StaticResource BasicBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="RenderOptions.EdgeMode" Value="Aliased" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="behaviors:BehaviorInStyleAttacher.Behaviors">
            <Setter.Value>
                <collections:ArrayList>
                    <behaviors:BridgeVisibilityBehavior
                        AllConnections="{Binding AllConnections}"
                        BridgeType="{Binding RelativeSource={RelativeSource AncestorType=Line, Mode=FindAncestor}, Path=Tag, Converter={StaticResource TagToBridgeTypeEnumConverter}}" />
                </collections:ArrayList>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PotentialConnectionStyle" TargetType="Rectangle">
        <Setter Property="Fill" Value="{StaticResource PotentialConnectionBrush}" />
    </Style>

    <DataTemplate x:Key="DataTemplateIsland" DataType="{x:Type viewModels:IslandViewModel}">
        <Border BorderThickness="0">
            <Grid UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Rectangle Width="33" Height="15" Style="{StaticResource PotentialConnectionStyle}" Margin="0,0,-2,0"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Visibility="{Binding IsHighlightHorizontalRight, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Rectangle Width="33" Height="15" Style="{StaticResource PotentialConnectionStyle}" Margin="-2,0,0,0"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Visibility="{Binding IsHighlightHorizontalLeft, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Rectangle Width="15" Height="33" Style="{StaticResource PotentialConnectionStyle}" Margin="0,-1,0,0"
                           HorizontalAlignment="Center" VerticalAlignment="Top"
                           Visibility="{Binding IsHighlightVerticalTop, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Rectangle Width="15" Height="33" Style="{StaticResource PotentialConnectionStyle}" Margin="0,0,0,-1"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Visibility="{Binding IsHighlightVerticalBottom, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Line X1="0" Y1="0" X2="60" Y2="0" Style="{StaticResource GridLinesStyle}" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" Stroke="LightGray" StrokeDashArray="4,4" StrokeThickness="1" 
                      Visibility="{Binding RelativeSource={RelativeSource AncestorType=mah:MetroWindow, Mode=FindAncestor}, Path=DataContext.Settings.AreGridLinesEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Line X1="0" Y1="0" X2="0" Y2="60" Style="{StaticResource GridLinesStyle}" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Stroke="LightGray" StrokeDashArray="4,4" StrokeThickness="1"
                      Visibility="{Binding RelativeSource={RelativeSource AncestorType=mah:MetroWindow, Mode=FindAncestor}, Path=DataContext.Settings.AreGridLinesEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!--Double Lines horizontal-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="-2" X2="60" Y2="-2" HorizontalAlignment="Center" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.HorizontalDouble}"/>
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="8" X2="60" Y2="8" HorizontalAlignment="Center" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.HorizontalDouble}"/>

                <!--Double Lines horizontal right-->
                <Line Style="{StaticResource BridgeStyle}" X1="30" Y1="-2" X2="60" Y2="-2" HorizontalAlignment="Right" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.HorizontalDoubleRight}"/>
                <Line Style="{StaticResource BridgeStyle}" X1="30" Y1="8" X2="60" Y2="8" HorizontalAlignment="Right" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.HorizontalDoubleRight}"/>

                <!--Double Lines horizontal left-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="-2" X2="30" Y2="-2" HorizontalAlignment="Left" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.HorizontalDoubleLeft}"/>
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="8" X2="30" Y2="8" HorizontalAlignment="Left" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.HorizontalDoubleLeft}" />

                <!--Double Lines vertical-->
                <Line Style="{StaticResource BridgeStyle}" X1="-3" Y1="0" X2="-3" Y2="60" HorizontalAlignment="Center" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.VerticalDouble}" />
                <Line Style="{StaticResource BridgeStyle}" X1="8" Y1="0" X2="8" Y2="60" HorizontalAlignment="Center" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.VerticalDouble}"/>

                <!--Double Lines vertical top-->
                <Line Style="{StaticResource BridgeStyle}" X1="-3" Y1="0" X2="-3" Y2="30" HorizontalAlignment="Center" VerticalAlignment="Top" Tag ="{x:Static enums:BridgeTypeEnum.VerticalDoubleUp}" />
                <Line Style="{StaticResource BridgeStyle}" X1="8" Y1="0" X2="8" Y2="30" HorizontalAlignment="Center" VerticalAlignment="Top" Tag ="{x:Static enums:BridgeTypeEnum.VerticalDoubleUp}"/>

                <!--Double Lines vertical bottom-->
                <Line Style="{StaticResource BridgeStyle}" X1="-3" Y1="30" X2="-3" Y2="60" HorizontalAlignment="Center" VerticalAlignment="Bottom" Tag ="{x:Static enums:BridgeTypeEnum.VerticalDoubleDown}"/>
                <Line Style="{StaticResource BridgeStyle}" X1="8" Y1="30" X2="8" Y2="60" HorizontalAlignment="Center" VerticalAlignment="Bottom" Tag ="{x:Static enums:BridgeTypeEnum.VerticalDoubleDown}"/>

                <!--Single line horizontal-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="0" X2="60" Y2="0" HorizontalAlignment="Center" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.Horizontal}"/>

                <!--Single line horizontal right-->
                <Line Style="{StaticResource BridgeStyle}" X1="30" Y1="0" X2="60" Y2="0" HorizontalAlignment="Right" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.HorizontalRight}" />

                <!--Single line horizontal left-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="0" X2="30" Y2="0" HorizontalAlignment="Left" VerticalAlignment="Center" Tag ="{x:Static enums:BridgeTypeEnum.HorizontalLeft}"/>

                <!--Single line vertical-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="0" X2="0" Y2="60" HorizontalAlignment="Center" VerticalAlignment="Center" Tag="{x:Static enums:BridgeTypeEnum.Vertical}"/>

                <!--Single line vertical top-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="0" X2="0" Y2="30" HorizontalAlignment="Center" VerticalAlignment="Top" Tag="{x:Static enums:BridgeTypeEnum.VerticalUp}"/>

                <!--Single line vertical bottom-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="30" X2="0" Y2="60" HorizontalAlignment="Center" VerticalAlignment="Bottom" Tag="{x:Static enums:BridgeTypeEnum.VerticalDown}"/>

                <Ellipse Width="40" Height="40" Fill="{Binding IslandColor.Brush}" HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Visibility="{Binding MaxConnections, Converter={StaticResource IslandVisibilityConverter}}"
                         IsHitTestVisible="True" AllowDrop="True" />
                <TextBlock Text="{Binding MaxConnections}" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" Foreground="{StaticResource BasicBrush}" FontWeight="Bold"
                           Visibility="{Binding MaxConnections, Converter={StaticResource IslandVisibilityConverter}}"
                           IsHitTestVisible="True" AllowDrop="True" />
                <b:Interaction.Behaviors>
                    <behaviors:IslandDragDropBehavior
                        DragEnterCommand="{Binding DragEnterCommand}"
                        DragOverCommand="{Binding DragOverCommand}"
                        DragLeaveCommand="{Binding DragLeaveCommand}"
                        DropCommand="{Binding DropCommand}"
                        MouseMoveCommand="{Binding MouseMoveCommand}"
                        MouseLeftButtonDownCommand="{Binding MouseLeftButtonDownCommand}"
                        MouseLeftButtonUpCommand="{Binding MouseLeftButtonUpCommand}"
                        ConnectedViewBox="{Binding RelativeSource={RelativeSource AncestorType=Viewbox, Mode=FindAncestor}}" />
                </b:Interaction.Behaviors>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="DataTemplateLevel1">
        <ItemsControl ItemsSource="{Binding}" ItemTemplate="{DynamicResource DataTemplateIsland}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </DataTemplate>
</ResourceDictionary>