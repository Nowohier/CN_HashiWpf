<mah:MetroWindow x:Class="Hashi.Gui.Views.HashiMainView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:System="clr-namespace:System;assembly=System.Runtime"
                 xmlns:viewModels="clr-namespace:Hashi.Gui.ViewModels"
                 xmlns:enums="clr-namespace:Hashi.Gui.Enums;assembly=Hashi.Enums"
                 xmlns:converters="clr-namespace:Hashi.Gui.Converters"
                 xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                 mc:Ignorable="d"
                 Loaded="Window_Loaded"
                 d:DataContext="{d:DesignInstance {x:Type viewModels:MainViewModel}, IsDesignTimeCreatable=False}"
                 Title="Hashiwokakero" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen"
                 AllowDrop="True" WindowTitleBrush="{StaticResource BasicBrush}">
    <mah:MetroWindow.IconTemplate>
        <DataTemplate>
            <Grid>
                <iconPacks:PackIconVaadinIcons Kind="Cluster" Style="{StaticResource WindowIconStyle}" Margin="5,0,0,0" />
            </Grid>
        </DataTemplate>
    </mah:MetroWindow.IconTemplate>
    <Window.Resources>
        <ObjectDataProvider x:Key="DifficultyEnums" MethodName="GetValues" ObjectType="{x:Type System:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:DifficultyEnum" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <converters:EmptyStringToBoolConverter x:Key="EmptyStringToBoolConverter" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderThickness="0,0,0,0" BorderBrush="{StaticResource BasicBrush}" Margin="0,0,0,0">
                <DockPanel LastChildFill="True">
                    <GroupBox Header="CREATE NEW GAME" Padding="5" Style="{x:Null}" DockPanel.Dock="Left"
                              BorderThickness="0,1,0,0" Margin="0,0,0,0" BorderBrush="{StaticResource BasicBrush}"
                              Background="{StaticResource MenuBackgroundBrush}">
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="DIFFICULTY:" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"
                                       DockPanel.Dock="Left" />
                            <ComboBox BorderBrush="#FFD5DFE5" Focusable="False" Width="85"
                                      SelectedItem="{Binding SelectedDifficulty}" DisplayMemberPath=""
                                      ItemsSource="{Binding Source={StaticResource DifficultyEnums}}"
                                      DockPanel.Dock="Left" />
                            <Button Style="{StaticResource MenuButtonStyle}" Padding="5,0,5,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding CreateNewGameCommand}" Margin="10,0,0,0" DockPanel.Dock="Left">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:Material Kind="StarPlusOutline" Width="14" Height="14" />
                                    <TextBlock Text="CREATE" Margin="5,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DockPanel>
                    </GroupBox>
                    <GroupBox Header="TIMES" Margin="10,0,0,0" Padding="5" Style="{x:Null}" DockPanel.Dock="Right"
                              BorderThickness="0,1,0,0" BorderBrush="{StaticResource BasicBrush}"
                              Background="{StaticResource MenuBackgroundBrush}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Timer" VerticalAlignment="Center"
                                                        Foreground="Red" Height="20" Width="20" />
                            <TextBlock Text="{Binding Timer.Elapsed, StringFormat={}{0:hh\\:mm\\:ss}}"
                                       Margin="10,0,0,0" FontSize="20"
                                       Foreground="Red" VerticalAlignment="Center" />
                            <iconPacks:PackIconMaterial Kind="Crown" Margin="30,0,0,0" VerticalAlignment="Center"
                                                        Foreground="{StaticResource IntenseGreenBrush}" Height="20"
                                                        Width="20" />
                            <TextBlock
                                Text="{Binding HighscoreForSelectedDifficulty, StringFormat={}{0:hh\\:mm\\:ss}, TargetNullValue='00:00:00'}"
                                Margin="10,0,0,0" FontSize="20"
                                Foreground="{StaticResource IntenseGreenBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="OTHER" Padding="5" Style="{x:Null}" Margin="10,0,0,0" BorderThickness="0,1,0,0"
                              BorderBrush="{StaticResource BasicBrush}"
                              Background="{StaticResource MenuBackgroundBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource MenuButtonStyle}" Padding="5,0,5,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding RemoveAllBridgesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:Material Kind="SortVariantRemove" Width="14" Height="14" />
                                    <TextBlock Text="REMOVE ALL BRIDGES" Margin="5,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <ToggleButton Style="{StaticResource MenuGridToggleButtonStyle}" Padding="5,0,5,0"
                                          IsChecked="{Binding Settings.AreGridLinesEnabled}" Margin="10,0,0,0"
                                          HorizontalAlignment="Left">
                            </ToggleButton>
                            <Button Style="{StaticResource MenuButtonStyle}" Command="{Binding GenerateHintCommand}" Padding="5,0,5,0" Margin="10,0,0,0"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:Material Kind="LightbulbOnOutline" Width="14" Height="14" />
                                    <TextBlock Text="SHOW HINT" Margin="5,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </GroupBox>
                </DockPanel>
            </Border>
        </Grid>

        <Grid x:Name="HashiGrid" Grid.Row="1" Margin="0,10,0,0">
            <Border BorderThickness="1" BorderBrush="{StaticResource BasicBrush}" CornerRadius="2"
                    Background="{StaticResource BackgroundBrush}">
                <Viewbox x:Name="HashiViewBox" Stretch="Uniform">
                    <ItemsControl Margin="5" IsHitTestVisible="True"
                                  ItemTemplate="{StaticResource DataTemplateLevel1}"
                                  ItemsSource="{Binding ConnectionManager.Islands}" HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch" />
                </Viewbox>
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              Visibility="{Binding IsGeneratingHashiPuzzle, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White" Opacity="0.5" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,5,0,0">
                <iconPacks:PackIconVaadinIcons Kind="Cluster" Width="32" Height="32" Spin="True" Margin="0,0,20,0"
                                               VerticalAlignment="Center" />
                <TextBlock Text="Please wait - generating Hashi puzzle..." FontSize="20" />
            </StackPanel>
        </Grid>


        <Popup Grid.Row="0" 
               Placement="Relative" 
               PlacementTarget="{Binding ElementName=HashiGrid}" 
               IsOpen="{Binding ConnectionManager.RuleMessage, Converter={StaticResource EmptyStringToBoolConverter}, Mode=OneWay}" 
               StaysOpen="False" 
               PopupAnimation="None" 
               Width="{Binding ElementName=HashiGrid, Path=ActualWidth}"
               Margin="-10,0,10,0"
               AllowsTransparency="True">
            <Border x:Name="PopupBorder" Opacity="0.8" CornerRadius="2" Background="{StaticResource GreenIslandBrush}" BorderThickness="1" BorderBrush="{StaticResource BasicBrush}">
                <TextBlock FontSize="16" TextWrapping="WrapWithOverflow" Margin="10">
                    <Run FontWeight="Bold"
                         Text="Hint: " />
                    <Run Text="{Binding ConnectionManager.RuleMessage, Mode=OneWay}" />
                </TextBlock>
            </Border>
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="Closed">
                    <b:InvokeCommandAction Command="{Binding HintPopUpClosedCommand}"/>
                </b:EventTrigger>
            </b:Interaction.Triggers>
        </Popup>
    </Grid>
</mah:MetroWindow>