<mah:MetroWindow x:Class="Hashi.Gui.Views.HashiMainView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:system="clr-namespace:System;assembly=System.Runtime"
                 xmlns:viewModels="clr-namespace:Hashi.Gui.ViewModels"
                 xmlns:converters="clr-namespace:Hashi.Gui.Converters"
                 xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:enums="clr-namespace:Hashi.Enums;assembly=Hashi.Enums"
                 mc:Ignorable="d"
                 Loaded="Window_Loaded"
                 d:DataContext="{d:DesignInstance {x:Type viewModels:MainViewModel}, IsDesignTimeCreatable=False}"
                 Title="Hashiwokakero" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen"
                 AllowDrop="True" WindowTitleBrush="{StaticResource BasicBrush}">
    <mah:MetroWindow.IconTemplate>
        <DataTemplate>
            <Grid>
                <iconPacks:PackIconVaadinIcons Kind="Cluster" Style="{StaticResource WindowIconStyle}" Margin="5,0,0,0" />
            </Grid>
        </DataTemplate>
    </mah:MetroWindow.IconTemplate>
    <Window.Resources>
        <ObjectDataProvider x:Key="DifficultyEnums" MethodName="GetValues" ObjectType="{x:Type system:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:DifficultyEnum" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <converters:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter" />
        <converters:MessageBackgroundBrushConverter x:Key="MessageBackgroundBrushConverter" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderThickness="0,0,0,0" BorderBrush="{StaticResource BasicBrush}" Margin="0,0,0,0">
                <DockPanel LastChildFill="True">
                    <GroupBox Header="CREATE NEW GAME" Padding="5" Style="{x:Null}" DockPanel.Dock="Left"
                              BorderThickness="0,1,0,0" Margin="0,0,0,0" BorderBrush="{StaticResource BasicBrush}"
                              Background="{StaticResource MenuBackgroundBrush}">
                        <DockPanel LastChildFill="False">

                            <ComboBox BorderBrush="#FFD5DFE5" Focusable="False" Width="85"
                                      SelectedItem="{Binding SelectedDifficulty}" DisplayMemberPath=""
                                      ItemsSource="{Binding Source={StaticResource DifficultyEnums}}"
                                      DockPanel.Dock="Left" />
                            <Button Style="{StaticResource MenuButtonStyle}" Padding="3,0,3,0" Width="30"
                                    HorizontalAlignment="Left" ToolTip="Create a new game" ToolTipService.InitialShowDelay="0"
                                    Command="{Binding CreateNewGameCommand}" Margin="10,0,0,0" DockPanel.Dock="Left">
                                <iconPacks:PackIconPhosphorIcons Kind="ShootingStarThin" Width="20" Height="20" />
                            </Button>
                        </DockPanel>
                    </GroupBox>
                    <GroupBox Header="TIMES" Margin="10,0,0,0" Padding="5" Style="{x:Null}" DockPanel.Dock="Right"
                              BorderThickness="0,1,0,0" BorderBrush="{StaticResource BasicBrush}"
                              Background="{StaticResource MenuBackgroundBrush}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconPhosphorIcons Kind="Timer" VerticalAlignment="Center"
                                                             Foreground="Red" Height="25" Width="25" />
                            <TextBlock Text="{Binding Timer.Elapsed, StringFormat={}{0:hh\\:mm\\:ss}}"
                                       Margin="10,0,0,0" FontSize="20"
                                       Foreground="Red" VerticalAlignment="Center" />
                            <iconPacks:PackIconPhosphorIcons Kind="Crown" Margin="30,0,0,0" VerticalAlignment="Center"
                                                             Foreground="{StaticResource IntenseGreenBrush}" Height="30"
                                                             Width="30" />
                            <TextBlock
                                Text="{Binding HighscoreForSelectedDifficulty, StringFormat={}{0:hh\\:mm\\:ss}, TargetNullValue='00:00:00'}"
                                Margin="10,0,0,0" FontSize="20"
                                Foreground="{StaticResource IntenseGreenBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="OPTIONS" Padding="5" Style="{x:Null}" Margin="10,0,0,0" BorderThickness="0,1,0,0"
                              BorderBrush="{StaticResource BasicBrush}"
                              Background="{StaticResource MenuBackgroundBrush}">
                        <DockPanel LastChildFill="False">
                            <Button Style="{StaticResource MenuButtonStyle}" Padding="3,0,3,0" Width="30"
                                    HorizontalAlignment="Left" ToolTip="Remove all Bridges" ToolTipService.InitialShowDelay="0"
                                    Command="{Binding RemoveAllBridgesCommand}" DockPanel.Dock="Left">
                                <Grid >
                                    <iconPacks:PackIconPhosphorIcons Kind="BridgeThin" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <iconPacks:PackIconPhosphorIcons Kind="ProhibitInsetThin" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Red"/>
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource MenuButtonStyle}" Command="{Binding GenerateHintCommand}" DockPanel.Dock="Left" Width="30" Padding="3,0,3,0" Margin="10,0,0,0"
                                    HorizontalAlignment="Left" ToolTip="Show Hint" ToolTipService.InitialShowDelay="0">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconPhosphorIcons Kind="LightbulbThin" Width="18" Height="18" />
                                </StackPanel>
                            </Button>
                            <ToggleButton Style="{StaticResource MenuGridToggleButtonStyle}" Padding="5,0,5,0"
                                          IsChecked="{Binding Settings.AreGridLinesEnabled}" Margin="10,0,0,0"
                                          HorizontalAlignment="Left" DockPanel.Dock="Left">
                            </ToggleButton>
                            
                            <Button Style="{StaticResource MenuButtonStyle}" Command="{Binding RedoCommand}" Padding="5,0,5,0" Margin="10,0,0,0" DockPanel.Dock="Right"
                                    ToolTip="Redo last step" ToolTipService.InitialShowDelay="0">
                                <iconPacks:PackIconPhosphorIcons Kind="ClockClockwiseThin" Width="18" Height="18"/>
                            </Button>
                            <Button Style="{StaticResource MenuButtonStyle}" Command="{Binding UndoCommand}" Padding="5,0,5,0" Margin="10,0,0,0" DockPanel.Dock="Right"
                                    ToolTip="Undo last step" ToolTipService.InitialShowDelay="0">
                                <iconPacks:PackIconPhosphorIcons Kind="ClockCounterClockwiseThin" Width="18" Height="18" />
                            </Button>
                            <Border DockPanel.Dock="Right" BorderThickness="0,0,1,0" Height="35" BorderBrush="Black"/>
                        </DockPanel>
                    </GroupBox>
                </DockPanel>
            </Border>
        </Grid>

        <Grid x:Name="HashiGrid" Grid.Row="1" Margin="0,10,0,0">
            <Border BorderThickness="1,1,1,0" BorderBrush="{StaticResource BasicBrush}" CornerRadius="2"
                    Background="{StaticResource BackgroundBrush}">
                <Viewbox x:Name="HashiViewBox" Stretch="Uniform">
                    <ItemsControl Margin="5" IsHitTestVisible="True"
                                  ItemTemplate="{StaticResource DataTemplateLevel1}"
                                  ItemsSource="{Binding ConnectionManager.Islands}" HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch" />
                </Viewbox>
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              Visibility="{Binding IsGeneratingHashiPuzzle, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White" Opacity="0.5" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,5,0,0">
                <iconPacks:PackIconVaadinIcons Kind="Cluster" Width="32" Height="32" Spin="True" Margin="0,0,20,0"
                                               VerticalAlignment="Center" />
                <TextBlock Text="Please wait - generating Hashi puzzle..." FontSize="20" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Width="{Binding ElementName=HashiViewBox, Path=ActualWidth}">
            <GroupBox Header="MESSAGES" Margin="-1,-10,-1,0" Padding="5" Style="{x:Null}" BorderThickness="1" Height="90"
                      BorderBrush="{StaticResource BasicBrush}"
                      Background="{Binding ConnectionManager.RuleMessage, Converter={StaticResource MessageBackgroundBrushConverter}}" 
                      >
                <Grid>
                    <TextBlock FontSize="16" TextWrapping="WrapWithOverflow" Margin="10,5,10,5" Visibility="{Binding ConnectionManager.RuleMessage, Converter={StaticResource EmptyStringToVisibilityConverter}}">
                        <Run FontWeight="Bold"
                             Text="Hint: " />
                        <Run Text="{Binding ConnectionManager.RuleMessage, Mode=OneWay}" />
                    </TextBlock>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="PreviewMouseDown">
            <b:InvokeCommandAction Command="{Binding WindowMouseClickedCommand}"/>
        </b:EventTrigger>
    </b:Interaction.Triggers>
</mah:MetroWindow>