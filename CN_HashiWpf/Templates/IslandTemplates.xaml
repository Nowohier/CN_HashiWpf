<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:viewModels="clr-namespace:CNHashiWpf.ViewModels"
                    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                    xmlns:behaviors="clr-namespace:CNHashiWpf.Behaviors"
                    xmlns:converters="clr-namespace:CNHashiWpf.Converters">

    <converters:IslandVisibilityConverter x:Key="IslandVisibilityConverter"/>
    <converters:DoubleLineVisibilityConverter x:Key="DoubleLineVisibilityConverter"/>
    <converters:SingleLineVisibilityConverter x:Key="SingleLineVisibilityConverter"/>
    <Style x:Key="BridgeStyle" TargetType="Line">
        <Setter Property="Stroke" Value="Black"/>
        <Setter Property="StrokeThickness" Value="2"/>
    </Style>

    <DataTemplate x:Key="DataTemplateIsland" DataType="{x:Type viewModels:IslandViewModel}">
        <Border BorderThickness="1">
            <Grid>
                <!--Double Lines horizontal right-->
                <Line Style="{StaticResource BridgeStyle}" X1="30" Y1="-2" X2="62" Y2="-2" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="{Binding BridgesRight, Converter={StaticResource DoubleLineVisibilityConverter}}"/>
                <Line Style="{StaticResource BridgeStyle}" X1="30" Y1="8" X2="62" Y2="8" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="{Binding BridgesRight, Converter={StaticResource DoubleLineVisibilityConverter}}"/>

                <!--Double Lines horizontal left-->
                <Line Style="{StaticResource BridgeStyle}" X1="-2" Y1="-2" X2="30" Y2="-2" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="{Binding BridgesLeft, Converter={StaticResource DoubleLineVisibilityConverter}}"/>
                <Line Style="{StaticResource BridgeStyle}" X1="-2" Y1="8" X2="30" Y2="8" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="{Binding BridgesLeft, Converter={StaticResource DoubleLineVisibilityConverter}}"/>

                <!--Double Lines vertical top-->
                <Line Style="{StaticResource BridgeStyle}" X1="-3" Y1="-2" X2="-3" Y2="30" HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="{Binding BridgesUp, Converter={StaticResource DoubleLineVisibilityConverter}}"/>
                <Line Style="{StaticResource BridgeStyle}" X1="8" Y1="-2" X2="8" Y2="30" HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="{Binding BridgesUp, Converter={StaticResource DoubleLineVisibilityConverter}}"/>

                <!--Double Lines vertical bottom-->
                <Line Style="{StaticResource BridgeStyle}" X1="-3" Y1="30" X2="-3" Y2="62" HorizontalAlignment="Center" VerticalAlignment="Bottom" Visibility="{Binding BridgesDown, Converter={StaticResource DoubleLineVisibilityConverter}}"/>
                <Line Style="{StaticResource BridgeStyle}" X1="8" Y1="30" X2="8" Y2="62" HorizontalAlignment="Center" VerticalAlignment="Bottom" Visibility="{Binding BridgesDown, Converter={StaticResource DoubleLineVisibilityConverter}}"/>

                <!--Single line horizontal right-->
                <Line Style="{StaticResource BridgeStyle}" X1="30" Y1="0" X2="62" Y2="0" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="{Binding BridgesRight, Converter={StaticResource SingleLineVisibilityConverter}}"/>

                <!--Single line horizontal left-->
                <Line Style="{StaticResource BridgeStyle}" X1="-2" Y1="0" X2="30" Y2="0" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="{Binding BridgesLeft, Converter={StaticResource SingleLineVisibilityConverter}}"/>

                <!--Single line vertical top-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="-2" X2="0" Y2="30" HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="{Binding BridgesUp, Converter={StaticResource SingleLineVisibilityConverter}}"/>

                <!--Single line vertical bottom-->
                <Line Style="{StaticResource BridgeStyle}" X1="0" Y1="30" X2="0" Y2="62" HorizontalAlignment="Center" VerticalAlignment="Bottom" Visibility="{Binding BridgesDown, Converter={StaticResource SingleLineVisibilityConverter}}"/>

                <Ellipse Width="40" Height="40" Fill="{Binding IslandColor}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding MaxConnections, Converter={StaticResource IslandVisibilityConverter}}" IsHitTestVisible="True" AllowDrop="True"/>
                <TextBlock Text="{Binding MaxConnections}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Visibility="{Binding MaxConnections, Converter={StaticResource IslandVisibilityConverter}}" IsHitTestVisible="True" AllowDrop="True"/>
                <b:Interaction.Behaviors>
                    <behaviors:IslandDragDropBehavior
                    DragEnterCommand="{Binding DragEnterCommand}"
                    DragOverCommand="{Binding DragOverCommand}"
                    DragLeaveCommand="{Binding DragLeaveCommand}"
                    DropCommand="{Binding DropCommand}"
                    MouseMoveCommand="{Binding MouseMoveCommand}" 
                    MouseLeftButtonDownCommand="{Binding MouseLeftButtonDownCommand}"
                    MouseLeftButtonUpCommand="{Binding MouseLeftButtonUpCommand}"
                    ConnectedViewBox="{Binding RelativeSource={RelativeSource AncestorType=Viewbox, Mode=FindAncestor}}"/>
                </b:Interaction.Behaviors>
            </Grid>
        </Border>
    </DataTemplate>
    <DataTemplate x:Key="DataTemplateLevel1">
        <ItemsControl ItemsSource="{Binding}" ItemTemplate="{DynamicResource DataTemplateIsland}" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </DataTemplate>
</ResourceDictionary>